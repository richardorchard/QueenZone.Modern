@model IReadOnlyList<ArticleArchiveItem>

@if (Model.Count == 0)
{
  <p>No published articles are available yet.</p>
}
else
{
  <ol class="qz-news-list">
    @foreach (var item in Model)
    {
      <li class="qz-news-row">
        <div>
          <div class="qz-card__kicker"><time datetime="@item.PublishedAt.ToString("yyyy-MM-dd")">@item.PublishedAt.ToString("dd MMMM yyyy")</time></div>
          <div class="qz-meta">@(string.IsNullOrWhiteSpace(item.CategoryName) ? "Article" : item.CategoryName)</div>
        </div>
        <div>
          <h2><a href="@item.DetailPath">@item.Title</a></h2>
          <p>@item.Excerpt</p>
        </div>
      </li>
    }
  </ol>
}
