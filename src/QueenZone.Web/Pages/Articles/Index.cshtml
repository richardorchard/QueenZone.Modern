@page "/articles"
@model IndexModel

<partial name="_PageHero" model='@(("Long-form Archive", "Articles", "In-depth features, essays and editorial packages from the preserved Queenzone archive.", "100+ features"))' />

<section class="qz-section">
  <div class="qz-container">
    <partial name="_Breadcrumbs" model="Model.Breadcrumbs" />

    @if (Model.CommunityItems.Count > 0)
    {
      <h2 class="qz-section-heading">Community articles</h2>
      <partial name="_ArticlesArchiveList" model="Model.CommunityItems" />
      <h2 class="qz-section-heading">Archive</h2>
    }

    <partial name="_ArticlesArchiveList" model="Model.Items" />

    <partial name="_ArchivePagination" model="ArticlesRoutes.GetArchivePaginationViewModel(Model.CurrentPage, Model.TotalPages)" />
  </div>
</section>