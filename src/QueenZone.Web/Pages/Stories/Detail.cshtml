@page "/stories/{id:int}/{slug}"
@model DetailModel

@if (Model.Item is not null)
{
  <section class="qz-article-hero">
    <img src="/design-system/assets/img-hero.jpg" alt="">
    <div class="qz-container qz-article-hero__content">
      <p class="article-nav"><a class="qz-button qz-button--ghost" style="color: var(--qz-white);" href="/stories">Back to stories archive</a></p>
      @if (!string.IsNullOrWhiteSpace(Model.Item.CategoryName))
      {
        <div class="qz-eyebrow" style="color: var(--qz-gold);">@Model.Item.CategoryName</div>
      }
      else
      {
        <div class="qz-eyebrow" style="color: var(--qz-gold);">Stories archive</div>
      }
      <h1>@Model.Item.Title</h1>
      <div class="qz-meta" style="color: rgba(255,255,255,0.52);"><time datetime="@Model.Item.PublishedAt.ToString("yyyy-MM-dd")">@Model.Item.PublishedAt.ToString("dd MMMM yyyy")</time></div>
    </div>
  </section>
  <div class="qz-reading">
    @if (!string.IsNullOrWhiteSpace(Model.Item.Excerpt))
    {
      <p class="lede">@Model.Item.Excerpt</p>
    }
    <article class="article-body">@Html.Raw(StoriesArticleContent.FormatBody(Model.Item.Body))</article>

    @if (!string.IsNullOrWhiteSpace(Model.Item.Source))
    {
      if (NewsArticleContent.IsSafePublicUrl(Model.Item.Source))
      {
        <p class="article-source"><a href="@Model.Item.Source" rel="noopener noreferrer">Source</a></p>
      }
      else
      {
        <p class="article-source">@Model.Item.Source</p>
      }
    }
  </div>
}