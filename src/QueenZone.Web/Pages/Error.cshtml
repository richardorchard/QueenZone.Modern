@page "/error/{statusCode:int?}"
@model QueenZone.Web.Pages.ErrorModel
@{
  ViewData["Title"] = $"{Model.Heading} - Queenzone";
  ViewData["Description"] = Model.Standfirst;
}

<partial name="_PageHero" model='@((Model.Eyebrow, Model.Heading, Model.Standfirst, ""))' />

<section class="qz-section qz-section--warm qz-error-page" aria-labelledby="error-actions-heading">
  <div class="qz-container qz-error-page__grid">
    <div class="qz-error-page__panel">
      <p class="qz-error-page__kicker">Where to go next</p>
      <h2 id="error-actions-heading">@Model.ActionHeading</h2>
      <p>
        The restored public archive is read-only and searchable. These entry points should get you back to the useful parts quickly.
      </p>
      <div class="qz-error-page__actions" aria-label="Suggested destinations">
        <a class="qz-button qz-button--cta" href="/">Home</a>
        <a class="qz-button qz-button--outline" href="/search">Search</a>
      </div>
    </div>

    <nav class="qz-error-page__links" aria-label="Archive sections">
      <a href="/news">
        <span>News</span>
        <small>Latest approved updates and restored archive items</small>
      </a>
      <a href="/articles">
        <span>Articles</span>
        <small>Features, interviews, and long-form archive writing</small>
      </a>
      <a href="/discography">
        <span>Discography</span>
        <small>Albums, tracks, and release history</small>
      </a>
      <a href="/forum">
        <span>Forum Archive</span>
        <small>Read-only public discussions from Queenzone history</small>
      </a>
    </nav>
  </div>

  @if (Model.HttpStatusCodeValue >= 500)
  {
    <div class="qz-container">
      <p class="qz-error-page__request">Error reference: @Model.RequestId</p>
    </div>
  }
</section>
