@page "/account/login"
@model LoginModel

<partial name="_PageHero" model='@(("Members", "Sign in", "Sign in to QueenZone with Google, Microsoft, Discord or GitHub.", ""))' />

<section class="qz-section">
  <div class="qz-container qz-prose">
    <div class="qz-account-providers">
      @if (Model.GoogleEnabled)
      {
        <a class="qz-button" href="/account/external-login?provider=Google&returnUrl=@Uri.EscapeDataString(Model.ReturnUrl)">Continue with Google</a>
      }
      @if (Model.MicrosoftEnabled)
      {
        <a class="qz-button" href="/account/external-login?provider=Microsoft&returnUrl=@Uri.EscapeDataString(Model.ReturnUrl)">Continue with Microsoft</a>
      }
      @if (Model.DiscordEnabled)
      {
        <a class="qz-button" href="/account/external-login?provider=Discord&returnUrl=@Uri.EscapeDataString(Model.ReturnUrl)">Continue with Discord</a>
      }
      @if (Model.GitHubEnabled)
      {
        <a class="qz-button" href="/account/external-login?provider=GitHub&returnUrl=@Uri.EscapeDataString(Model.ReturnUrl)">Continue with GitHub</a>
      }
    </div>
  </div>
</section>
