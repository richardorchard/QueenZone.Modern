@page "/account/sign-in"
@model SignInModel

<partial name="_PageHero" model='@(("Members", "Sign in with email", "Use your Queenzone.org email and password.", ""))' />

<section class="qz-section">
  <div class="qz-container qz-prose">
    @if (Model.Error is not null)
    {
      <p class="qz-error">@Model.Error</p>
    }
    <form method="post">
      <input type="hidden" name="returnUrl" value="@Model.ReturnUrl">
      <label>
        Email
        <input type="email" name="email" required>
      </label>
      <label>
        Password
        <input type="password" name="password" required>
      </label>
      <button type="submit">Sign in</button>
    </form>
    <p><a href="/account/login?returnUrl=@Uri.EscapeDataString(Model.ReturnUrl)">Back to sign in options</a></p>
  </div>
</section>
