@page "/account/register"
@model RegisterModel

<partial name="_PageHero" model='@(("Members", "Create your Queenzone.org account", "Sign up with an email and password.", ""))' />

<section class="qz-section">
  <div class="qz-container qz-prose">
    @if (Model.Error is not null)
    {
      <p class="qz-error">@Model.Error</p>
    }
    <form method="post">
      <input type="hidden" name="returnUrl" value="@Model.ReturnUrl">
      <label>
        Display name
        <input type="text" name="displayName" required>
      </label>
      <label>
        Email
        <input type="email" name="email" required>
      </label>
      <label>
        Password
        <input type="password" name="password" required minlength="8">
      </label>
      <button type="submit">Create account</button>
    </form>
    <p><a href="/account/login?returnUrl=@Uri.EscapeDataString(Model.ReturnUrl)">Back to sign in</a></p>
  </div>
</section>
