@page "/account/settings"
@model SettingsModel

<partial name="_PageHero" model='@(("Members", "Account settings", "Update the name shown on your posts and contributions.", ""))' />

<section class="qz-section">
  <div class="qz-container qz-prose">
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
      <p class="qz-account-notice qz-account-notice--success" role="status">@Model.StatusMessage</p>
    }

    <div class="qz-account-settings">
      <dl class="qz-account-settings__meta">
        <div>
          <dt>Email</dt>
          <dd>@Model.Email</dd>
        </div>
        <div>
          <dt>Linked sign-in providers</dt>
          <dd>
            @if (Model.LinkedProviders.Count == 0)
            {
              <span>None linked</span>
            }
            else
            {
              <ul class="qz-account-settings__providers">
                @foreach (var provider in Model.LinkedProviders)
                {
                  <li>@provider</li>
                }
              </ul>
            }
          </dd>
        </div>
      </dl>

      <section class="qz-account-settings__avatar" aria-labelledby="avatar-heading">
        <h2 id="avatar-heading" class="qz-account-settings__section-title">Profile avatar</h2>
        <div class="qz-account-settings__avatar-row">
          <partial name="_MemberAvatar" model="@(new MemberAvatarViewModel { DisplayName = Model.DisplayName, MemberId = Model.MemberId, HasAvatar = Model.HasAvatar, Size = "md" })" />
          <div class="qz-account-settings__avatar-forms">
            <form method="post"
                  asp-page-handler="UploadAvatar"
                  enctype="multipart/form-data"
                  class="qz-account-form"
                  data-busy-submit
                  data-busy-label="Uploading…">
              @Html.AntiForgeryToken()
              <label class="qz-account-form__field">
                <span>Upload image</span>
                <input asp-for="AvatarFile"
                       type="file"
                       accept="image/jpeg,image/png,image/webp,.jpg,.jpeg,.png,.webp"
                       required />
                <span asp-validation-for="AvatarFile" class="qz-account-form__field-error"></span>
                <span class="qz-account-form__help">
                  JPEG, PNG, or WebP. Max 2&nbsp;MB. Cropped to a square and stored as WebP.
                </span>
              </label>
              <div class="qz-account-form__actions">
                <button type="submit" class="qz-button">Upload avatar</button>
              </div>
              <p class="qz-account-form__status" data-busy-status hidden role="status" aria-live="polite"></p>
            </form>
            @if (Model.HasAvatar)
            {
              <form method="post"
                    asp-page-handler="RemoveAvatar"
                    class="qz-account-form"
                    data-busy-submit
                    data-busy-label="Removing…">
                @Html.AntiForgeryToken()
                <div class="qz-account-form__actions">
                  <button type="submit" class="qz-button qz-button--outline">Remove avatar</button>
                </div>
                <p class="qz-account-form__status" data-busy-status hidden role="status" aria-live="polite"></p>
              </form>
            }
          </div>
        </div>
      </section>

      <form method="post"
            class="qz-account-form"
            novalidate
            data-busy-submit
            data-busy-label="Saving…">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="qz-account-form__errors" role="alert"></div>

        <label class="qz-account-form__field">
          <span>Display name</span>
          <input asp-for="DisplayName"
                 type="text"
                 maxlength="@MemberAccountService.MaxDisplayNameLength"
                 minlength="@MemberAccountService.MinDisplayNameLength"
                 required
                 autocomplete="nickname"
                 aria-describedby="display-name-help" />
          <span asp-validation-for="DisplayName" class="qz-account-form__field-error"></span>
          <span id="display-name-help" class="qz-account-form__help">
            2–100 characters. This name appears on forum posts, photo attributions, and other contributions. Display names do not need to be unique.
          </span>
        </label>

        <div class="qz-account-form__actions">
          <button type="submit" class="qz-button">Save display name</button>
        </div>
        <p class="qz-account-form__status" data-busy-status hidden role="status" aria-live="polite"></p>
      </form>
    </div>
  </div>
</section>
