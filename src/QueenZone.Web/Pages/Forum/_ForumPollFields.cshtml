@model ForumPollForm
@{
  var poll = Model ?? new ForumPollForm();
}

<div class="qz-form__field qz-forum-poll-compose" data-forum-poll-compose>
  <label class="qz-forum-poll-compose__toggle">
    <input type="hidden" name="Poll.Enabled" value="false" />
    <input type="checkbox"
           name="Poll.Enabled"
           value="true"
           data-poll-toggle
           @(poll.Enabled ? "checked" : null) />
    Add a poll
  </label>

  <div class="qz-forum-poll-compose__fields" data-poll-fields @(poll.Enabled ? null : "hidden")>
    <div class="qz-form__field">
      <label for="Poll_Question">Poll question</label>
      <input id="Poll_Question"
             name="Poll.Question"
             type="text"
             maxlength="300"
             value="@poll.Question"
             data-poll-question />
    </div>

    <div class="qz-form__field">
      <label>Options</label>
      <div class="qz-forum-poll-compose__options" data-poll-options>
        @{
          var optionList = poll.Options is { Count: > 0 } ? poll.Options : new List<string> { "", "" };
          for (var i = 0; i < optionList.Count; i++)
          {
            <div class="qz-forum-poll-compose__option-row" data-poll-option-row>
              <input type="text"
                     name="Poll.Options[@i]"
                     maxlength="200"
                     value="@optionList[i]"
                     placeholder="Option @(i + 1)" />
              <button type="button" class="qz-button qz-button--ghost" data-poll-remove-option aria-label="Remove option">Remove</button>
            </div>
          }
        }
      </div>
      <p class="qz-meta">2–10 options. Votes are final.</p>
      <button type="button" class="qz-button qz-button--ghost" data-poll-add-option>Add option</button>
    </div>

    <div class="qz-form__field">
      <label class="qz-forum-poll-compose__toggle">
        <input type="checkbox"
               name="Poll.IsMultiChoice"
               value="true"
               data-poll-multi
               @(poll.IsMultiChoice ? "checked" : null) />
        Allow multiple choices
      </label>
    </div>

    <div class="qz-form__field" data-poll-max-choices-wrap @(poll.IsMultiChoice ? null : "hidden")>
      <label for="Poll_MaxChoices">Max choices (optional)</label>
      <input id="Poll_MaxChoices"
             name="Poll.MaxChoices"
             type="number"
             min="1"
             max="10"
             value="@poll.MaxChoices" />
    </div>

    <div class="qz-form__field">
      <label for="Poll_ClosesAt">Close date (optional, UTC)</label>
      <input id="Poll_ClosesAt"
             name="Poll.ClosesAt"
             type="datetime-local"
             value="@(poll.ClosesAt?.ToString("yyyy-MM-ddTHH:mm"))" />
    </div>
  </div>
</div>

<script>
(function () {
  var root = document.querySelector("[data-forum-poll-compose]");
  if (!root) return;
  var toggle = root.querySelector("[data-poll-toggle]");
  var fields = root.querySelector("[data-poll-fields]");
  var options = root.querySelector("[data-poll-options]");
  var addBtn = root.querySelector("[data-poll-add-option]");
  var multi = root.querySelector("[data-poll-multi]");
  var maxWrap = root.querySelector("[data-poll-max-choices-wrap]");
  var maxOptions = 10;
  var minOptions = 2;

  function reindex() {
    var rows = options.querySelectorAll("[data-poll-option-row]");
    rows.forEach(function (row, index) {
      var input = row.querySelector("input[type=text]");
      if (input) input.name = "Poll.Options[" + index + "]";
      var remove = row.querySelector("[data-poll-remove-option]");
      if (remove) remove.hidden = rows.length <= minOptions;
    });
  }

  function setEnabled(on) {
    fields.hidden = !on;
  }

  toggle && toggle.addEventListener("change", function () {
    setEnabled(toggle.checked);
  });

  multi && multi.addEventListener("change", function () {
    if (maxWrap) maxWrap.hidden = !multi.checked;
  });

  addBtn && addBtn.addEventListener("click", function () {
    var rows = options.querySelectorAll("[data-poll-option-row]");
    if (rows.length >= maxOptions) return;
    var row = document.createElement("div");
    row.className = "qz-forum-poll-compose__option-row";
    row.setAttribute("data-poll-option-row", "");
    row.innerHTML =
      '<input type="text" maxlength="200" placeholder="Option" />' +
      '<button type="button" class="qz-button qz-button--ghost" data-poll-remove-option aria-label="Remove option">Remove</button>';
    options.appendChild(row);
    reindex();
  });

  options && options.addEventListener("click", function (event) {
    var btn = event.target.closest("[data-poll-remove-option]");
    if (!btn) return;
    var rows = options.querySelectorAll("[data-poll-option-row]");
    if (rows.length <= minOptions) return;
    var row = btn.closest("[data-poll-option-row]");
    if (row) row.remove();
    reindex();
  });

  reindex();
})();
</script>
