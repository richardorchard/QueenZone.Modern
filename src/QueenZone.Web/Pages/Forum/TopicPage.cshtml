@page "/forum/topic/{topicId:int}/{slug}/page/{pageNumber:int}"
@model TopicPageModel
@{
  var header = Model.Header!;
  var categoryPath = ForumRoutes.GetCategoryCanonicalPath(header.ForumId, header.ForumName);
}

<section class="qz-page-hero">
  <img class="qz-page-hero__crest" src="/design-system/assets/crest-white.png" alt="">
  <div class="qz-container">
    <div class="qz-eyebrow" style="color: var(--qz-gold);">
      <a href="/forum" style="color: inherit;">Forum</a>
      <span aria-hidden="true"> · </span>
      <a href="@categoryPath" style="color: inherit;">@header.ForumName</a>
    </div>
    <h1>@header.Title</h1>
    <div class="qz-forum-stats">
      <span><strong>@Model.TotalPosts.ToString("N0")</strong> posts</span>
      <span>Page <strong>@Model.CurrentPage</strong> of <strong>@Model.TotalPages</strong></span>
    </div>
  </div>
</section>

<section class="qz-section">
  <div class="qz-container">
    <partial name="_SectionHeader" model="@(("Thread", "Posts in chronological order", false, (string?)null, (string?)null))" />
    <partial name="_ForumPostList" model="Model.Posts" />
    <partial name="_ArchivePagination" model="ForumRoutes.GetTopicPaginationViewModel(header, Model.CurrentPage, Model.TotalPages)" />
  </div>
</section>