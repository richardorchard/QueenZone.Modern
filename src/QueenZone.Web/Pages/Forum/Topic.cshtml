@page "/forum/topic/{topicId:int}/{slug}"
@model TopicModel
@{
  var header = Model.Header!;
  ViewData["TextareaId"] = "Body";
  ViewData["TextareaName"] = "Body";
  ViewData["EditorValue"] = Model.Body;
  ViewData["EditorLabel"] = "Reply";
}

<section class="qz-page-hero">
  <partial name="_PictureImage" model="@("/design-system/assets/crest-white.png", "", false, "qz-page-hero__crest")" />
  <div class="qz-container qz-breadcrumbs-on-dark">
    <partial name="_Breadcrumbs" model="Model.Breadcrumbs" />
    <h1>@header.Title</h1>
    <div class="qz-forum-stats">
      <span><strong>@Model.TotalPosts.ToString("N0")</strong> posts</span>
    </div>
  </div>
</section>

<section class="qz-section">
  <div class="qz-container">
    <partial name="_SectionHeader" model="@(("Thread", "Posts in chronological order", false, "/search", "Search forum"))" />
    <partial name="_ForumPostList" model="Model.Posts" />
    <partial name="_ArchivePagination" model="ForumRoutes.GetTopicPaginationViewModel(header, Model.CurrentPage, Model.TotalPages)" />
    @if (Model.CanReply)
    {
      <form method="post" class="qz-form">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="qz-form__validation"></div>
        <partial name="_RichTextEditor" />
        <span asp-validation-for="Body"></span>
        <button class="qz-button" type="submit">Reply</button>
      </form>
    }
    else
    {
      <p><a class="qz-button" href="/account/login?returnUrl=@Uri.EscapeDataString(HttpContext.Request.Path)">Sign in to reply</a></p>
    }
  </div>
</section>
