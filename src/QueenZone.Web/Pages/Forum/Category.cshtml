@page "/forum/{id:int}/{slug}"
@model CategoryModel
@{
  var category = Model.Category!;
}

<section class="qz-page-hero">
  <partial name="_PictureImage" model="@("/design-system/assets/crest-white.png", "", false, "qz-page-hero__crest")" />
  <div class="qz-container qz-breadcrumbs-on-dark">
    <partial name="_Breadcrumbs" model="Model.Breadcrumbs" />
    <h1>@category.Name</h1>
    @if (!string.IsNullOrWhiteSpace(category.Description))
    {
      <p class="lede" style="max-width: var(--container-text);">@category.Description</p>
    }
    <div class="qz-forum-stats">
      <span><strong>@Model.TotalTopics.ToString("N0")</strong> threads</span>
      <span><strong>@ForumRoutes.FormatCount(category.PostCount)</strong> posts</span>
    </div>
  </div>
</section>

<section class="qz-section">
  <div class="qz-container">
    <partial name="_SectionHeader" model="@(("Topics", "Threads in this board", false, Model.CanCreateThread ? ForumRoutes.GetNewThreadPath(category) : "/search", Model.CanCreateThread ? "New thread" : "Search forum"))" />
    <partial name="_ForumTopicList" model="@(category, Model.Topics)" />
    <partial name="_ArchivePagination" model="ForumRoutes.GetCategoryPaginationViewModel(category, Model.CurrentPage, Model.TotalPages)" />
  </div>
</section>
