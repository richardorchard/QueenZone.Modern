@model IReadOnlyList<ForumPostItem>

@if (Model.Count == 0)
{
  <p>No posts are available in this thread yet.</p>
}
else
{
  <div class="qz-forum-posts">
    @foreach (var post in Model)
    {
      <article class="qz-forum-post" id="post-@post.Id">
        <header class="qz-forum-post__header">
          <div>
            <strong class="qz-forum-post__author">@post.AuthorUsername</strong>
            @if (post.AuthorMemberSince is not null)
            {
              <span class="qz-meta"> · Member since <time datetime="@post.AuthorMemberSince.Value.ToString("yyyy-MM-dd")">@post.AuthorMemberSince.Value.ToString("MMMM yyyy")</time></span>
            }
          </div>
          <time class="qz-meta" datetime="@post.PostedAt.ToString("yyyy-MM-ddTHH:mm:ss")">@post.PostedAt.ToString("dd MMMM yyyy HH:mm")</time>
        </header>
        <div class="qz-forum-post__body article-body">@Html.Raw(NewsArticleContent.FormatBody(post.Body))</div>
        @if (!string.IsNullOrWhiteSpace(post.Signature))
        {
          <footer class="qz-forum-post__signature qz-meta">@post.Signature</footer>
        }
      </article>
    }
  </div>
}