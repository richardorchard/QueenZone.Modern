@model (ForumCategoryItem Category, IReadOnlyList<ForumTopicItem> Topics)

@if (Model.Topics.Count == 0)
{
  <p>No topics are available in this board yet.</p>
}
else
{
  <table class="qz-table">
    <thead>
      <tr>
        <th>Thread</th>
        <th>Author</th>
        <th>Replies</th>
        <th>Last post</th>
      </tr>
    </thead>
    <tbody>
      @foreach (var topic in Model.Topics)
      {
        <tr>
          <td>
            @if (topic.IsSticky)
            {
              <span class="qz-meta">Pinned · </span>
            }
            <a href="@ForumRoutes.GetTopicPath(topic)">@topic.Title</a>
          </td>
          <td>@topic.AuthorUsername</td>
          <td>@topic.ReplyCount.ToString("N0")</td>
          <td>
            @if (!string.IsNullOrWhiteSpace(topic.LastPostUsername))
            {
              <span>@topic.LastPostUsername · </span>
            }
            <time datetime="@topic.LastActivityAt.ToString("yyyy-MM-dd")">@topic.LastActivityAt.ToString("dd MMMM yyyy")</time>
          </td>
        </tr>
      }
    </tbody>
  </table>
}