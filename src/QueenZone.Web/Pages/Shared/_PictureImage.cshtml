@model (string Src, string Alt, bool Lazy, string? CssClass)
@inject IFileVersionProvider FileVersionProvider
@inject IWebHostEnvironment HostEnv
@{
    var pathBase = ViewContext.HttpContext.Request.PathBase;
    var versionedSrc = VersionedStaticPath.Apply(FileVersionProvider, pathBase, Model.Src);
    var webpSrc = VersionedStaticPath.TryGetVersionedWebpSrc(FileVersionProvider, HostEnv, pathBase, Model.Src);
}
<picture class="@Model.CssClass">
  @if (webpSrc is not null)
  {
    <source srcset="@webpSrc" type="image/webp">
  }
  <img src="@versionedSrc" alt="@Model.Alt" loading="@(Model.Lazy ? "lazy" : "eager")" decoding="async">
</picture>
