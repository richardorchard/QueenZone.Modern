@model (string Src, string Alt, bool Lazy)
@inject IWebHostEnvironment HostEnv
@{
    string? webpSrc = null;
    if (Model.Src.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase))
    {
        var relative = Model.Src.TrimStart('/').Replace('/', System.IO.Path.DirectorySeparatorChar);
        var webpRelative = System.IO.Path.ChangeExtension(relative, ".webp");
        if (System.IO.File.Exists(System.IO.Path.Combine(HostEnv.WebRootPath, webpRelative)))
        {
            webpSrc = "/" + webpRelative.Replace(System.IO.Path.DirectorySeparatorChar, '/');
        }
    }
}
<picture>
  @if (webpSrc is not null)
  {
    <source srcset="@webpSrc" type="image/webp">
  }
  <img src="@Model.Src" alt="@Model.Alt" loading="@(Model.Lazy ? "lazy" : "eager")" decoding="async">
</picture>
