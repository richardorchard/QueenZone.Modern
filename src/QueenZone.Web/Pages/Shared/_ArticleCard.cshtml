@model (string Image, string Category, string Title, string Excerpt, string Meta, string Href, bool OnDark)

<a class="qz-article-card @(Model.OnDark ? "qz-on-dark" : "")" href="@Model.Href">
  <div class="qz-article-card__media">
    <partial name="_PictureImage" model="@(Model.Image, "", true, (string?)null)" />
  </div>
  <div class="qz-card__kicker">@Model.Category</div>
  <h3>@Model.Title</h3>
  <p>@Model.Excerpt</p>
  <div class="qz-meta">@Model.Meta</div>
</a>
