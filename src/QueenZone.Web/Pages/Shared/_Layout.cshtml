@using Microsoft.Extensions.Options
@using QueenZone.Web.Sitemap
@inject IOptions<SiteOptions> SiteOptionsAccessor
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>@ViewData["Title"]</title>
  @if (ViewData["CanonicalPath"] is string canonicalPath)
  {
    <link rel="canonical" href="@SiteUrl.ToAbsolute(SiteOptionsAccessor.Value.PublicBaseUrl, canonicalPath)">
  }
  @if (ViewData["PrevPath"] is string prevPath)
  {
    <link rel="prev" href="@SiteUrl.ToAbsolute(SiteOptionsAccessor.Value.PublicBaseUrl, prevPath)">
  }
  @if (ViewData["NextPath"] is string nextPath)
  {
    <link rel="next" href="@SiteUrl.ToAbsolute(SiteOptionsAccessor.Value.PublicBaseUrl, nextPath)">
  }
  @if (ViewData["Description"] is string description)
  {
    <meta name="description" content="@description">
  }
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <partial name="_GoogleAnalytics" />
  <link rel="preload" href="/design-system/fonts/inter-latin-400-700.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/design-system/fonts/cormorant-garamond-latin-300-700.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="stylesheet" href="/design-system/tokens/fonts.css" asp-append-version="true">
  <link rel="stylesheet" href="/design-system/tokens/colors.css" asp-append-version="true">
  <link rel="stylesheet" href="/design-system/tokens/typography.css" asp-append-version="true">
  <link rel="stylesheet" href="/design-system/tokens/spacing.css" asp-append-version="true">
  <link rel="stylesheet" href="/design-system/tokens/base.css" asp-append-version="true">
  <link rel="stylesheet" href="/css/site.css" asp-append-version="true">
@await RenderSectionAsync("Head", required: false)
</head>
<body>
  <partial name="_SiteHeader" />
  <main>
    @RenderBody()
  </main>
  <partial name="_SiteFooter" />
  <partial name="_BuildStamp" />
  <script src="/js/site.js" asp-append-version="true" defer></script>
  @await RenderSectionAsync("Scripts", required: false)
</body>
</html>


