@page "/news"
@model IndexModel

<partial name="_PageHero" model='@(("The Archive", "News", "Chronological entries from the preserved Queenzone.com archive, with space for newly approved news articles.", "4,000+ articles"))' />

<section class="qz-section">
  <div class="qz-container">
    <partial name="_Breadcrumbs" model="Model.Breadcrumbs" />
    <div class="qz-tag-row">
      <span class="qz-tag qz-tag--active">All</span><span class="qz-tag">1985</span><span class="qz-tag">1986</span><span class="qz-tag">1991</span><span class="qz-tag">1992</span>
    </div>
    <partial name="_NewsArchiveList" model="Model.Items" />

    <partial name="_ArchivePagination" model="NewsRoutes.GetArchivePaginationViewModel(Model.CurrentPage, Model.TotalPages)" />
  </div>
</section>
