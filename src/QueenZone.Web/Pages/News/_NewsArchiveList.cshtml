@model IReadOnlyList<NewsItem>

@if (Model.Count == 0)
{
  <p>No published news is available yet.</p>
}
else
{
  <ol class="news-list">
    @foreach (var item in Model)
    {
      <li>
        <a href="@NewsRoutes.GetNewsDetailPath(item)">@item.Title</a>
        <p>@item.Excerpt</p>
        <time datetime="@item.PublishedAt.ToString("yyyy-MM-dd")">@item.PublishedAt.ToString("dd MMMM yyyy")</time>
      </li>
    }
  </ol>
}
