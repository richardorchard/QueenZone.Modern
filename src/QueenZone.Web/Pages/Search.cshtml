@page "/search"
@model SearchModel
@using QueenZone.Web
@{
  ViewData["Title"] = string.IsNullOrWhiteSpace(Model.Query)
    ? "Search"
    : $"Search: {Model.Query}";
  ViewData["Description"] = "Search the Queenzone archive — articles, photographs and forum discussions.";

  var exampleTags = new[] { "Bohemian Rhapsody", "Live Aid 1985", "Freddie Mercury", "Wembley 1986" };
}

<partial name="_PageHero" model='@(("Search the Archive", "Search", "Search 4,000+ articles, photographs and discussions.", "Articles, photos and discussions"))' />

<section class="qz-section">
  <div class="qz-container" style="max-width: 760px;">
    <form method="get" action="/search">
      <label class="qz-eyebrow" for="qz-search">Search query</label>
      <div style="display: flex; gap: var(--space-3); margin-top: var(--space-3);">
        <input id="qz-search"
               name="q"
               type="search"
               value="@Model.Query"
               placeholder="Search articles, photos and discussions..."
               autocomplete="off"
               style="flex: 1; padding: 1rem 1.125rem; border: 1px solid var(--border-strong); border-radius: var(--radius-xs); font: var(--type-body);">
        <button type="submit" class="qz-button" style="white-space: nowrap;">Search</button>
      </div>
    </form>

    @if (string.IsNullOrWhiteSpace(Model.Query))
    {
      <div class="qz-tag-row" style="margin-top: var(--space-5);">
        @foreach (var tag in exampleTags)
        {
          <a class="qz-tag" href="/search?q=@Uri.EscapeDataString(tag)">@tag</a>
        }
      </div>
    }
  </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.Query))
{
  <section class="qz-section">
    <div class="qz-container" style="max-width: 760px;">

      @if (Model.Results is null || Model.Results.TotalCount == 0)
      {
        <p class="qz-meta">No results found for <strong>@Model.Query</strong>. Try different keywords.</p>
      }
      else
      {
        <partial name="_SectionHeader" model="@(($"{Model.Results.TotalCount:N0} result{(Model.Results.TotalCount == 1 ? "" : "s")} for \"{Model.Query}\"", "Forum threads", false, (string?)null, (string?)null))" />

        <table class="qz-table">
          <thead>
            <tr>
              <th>Thread</th>
              <th>Board</th>
              <th>Replies</th>
              <th>Last post</th>
            </tr>
          </thead>
          <tbody>
            @foreach (var result in Model.Results.Results)
            {
              <tr>
                <td><a href="@ForumRoutes.GetTopicCanonicalPath(result.TopicId, result.Title)">@result.Title</a></td>
                <td><a href="@ForumRoutes.GetCategoryCanonicalPath(result.CategoryId, result.CategoryName)">@result.CategoryName</a></td>
                <td>@result.ReplyCount.ToString("N0")</td>
                <td>
                  @if (result.LastActivityAt.HasValue)
                  {
                    <time datetime="@result.LastActivityAt.Value.ToString("yyyy-MM-dd")">@result.LastActivityAt.Value.ToString("dd MMM yyyy")</time>
                  }
                </td>
              </tr>
            }
          </tbody>
        </table>

        var pagination = ArchivePagination.BuildViewModel(
          "Search results pagination",
          Model.CurrentPage,
          Model.TotalPages,
          p => p <= 1
            ? $"/search?q={Uri.EscapeDataString(Model.Query!)}"
            : $"/search?q={Uri.EscapeDataString(Model.Query!)}&page={p}");
        <partial name="_ArchivePagination" model="pagination" />
      }

    </div>
  </section>
}
