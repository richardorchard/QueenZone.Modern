@page "/admin"
@model QueenZone.Web.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Admin Dashboard";

    // Build a 30-day registration lookup for the sparkline.
    var utcToday = DateOnly.FromDateTime(DateTime.UtcNow);
    var regsByDate = Model.DailyRegistrations.ToDictionary(r => r.Date, r => r.Count);
    var sparkDays = Enumerable.Range(0, 30)
        .Select(i => utcToday.AddDays(i - 29))
        .Select(d => regsByDate.TryGetValue(d, out var c) ? c : 0)
        .ToList();

    const int svgW = 300;
    const int svgH = 48;
    const int padX = 2;
    var maxVal = sparkDays.Max() is > 0 ? sparkDays.Max() : 1;
    var stepX = (svgW - padX * 2.0) / (sparkDays.Count - 1);

    string SparkPoint(int i, int val)
    {
        var x = padX + i * stepX;
        var y = svgH - 4 - (val / (double)maxVal) * (svgH - 8);
        return $"{x:F1},{y:F1}";
    }
    var polyline = string.Join(" ", sparkDays.Select((v, i) => SparkPoint(i, v)));

    var trafficDaysByDate = Model.Traffic.DailySessionsLast30Days
        .Where(d => d.Date != DateOnly.MinValue)
        .ToDictionary(d => d.Date, d => d.Sessions);
    var trafficDays = Enumerable.Range(0, 30)
        .Select(i => utcToday.AddDays(i - 29))
        .Select(d => trafficDaysByDate.TryGetValue(d, out var c) ? c : 0)
        .ToList();
    var trafficMax = trafficDays.Max() is > 0 ? trafficDays.Max() : 1;

    string TrafficBarHeight(int val)
    {
        var height = Math.Max(2, (int)Math.Round((val / (double)trafficMax) * 42));
        return $"{height}px";
    }
}

<div class="admin-shell">
  <h1 class="admin-dashboard__title">Dashboard</h1>

  <section class="admin-dashboard__section" aria-labelledby="admin-sections-heading">
    <h2 id="admin-sections-heading" class="admin-dashboard__section-title">Admin sections</h2>
    <nav class="admin-dashboard__nav" aria-label="Admin sections">
      <a class="admin-dashboard__nav-link" href="/admin/news">
        <span class="admin-dashboard__nav-link-title">News articles</span>
        <span class="admin-dashboard__nav-link-desc">Create, edit, and publish editorial news</span>
      </a>
      <a class="admin-dashboard__nav-link" href="/admin/news-discovery">
        <span class="admin-dashboard__nav-link-title">AI discovery</span>
        <span class="admin-dashboard__nav-link-desc">Review AI-discovered news candidates</span>
      </a>
      <a class="admin-dashboard__nav-link" href="/admin/photos">
        <span class="admin-dashboard__nav-link-title">Photos</span>
        <span class="admin-dashboard__nav-link-desc">Manage the public photography gallery</span>
      </a>
      <a class="admin-dashboard__nav-link" href="/admin/photo-submissions">
        <span class="admin-dashboard__nav-link-title">Photo submissions</span>
        <span class="admin-dashboard__nav-link-desc">Review member photo uploads</span>
      </a>
      <a class="admin-dashboard__nav-link" href="/admin/news-suggestions">
        <span class="admin-dashboard__nav-link-title">News suggestions</span>
        <span class="admin-dashboard__nav-link-desc">Review member news tips</span>
      </a>
      <a class="admin-dashboard__nav-link" href="/admin/articles">
        <span class="admin-dashboard__nav-link-title">Article submissions</span>
        <span class="admin-dashboard__nav-link-desc">Review member article drafts</span>
      </a>
    </nav>
  </section>

  <section class="admin-dashboard__section">
    <h2 class="admin-dashboard__section-title">Members</h2>
    <div class="admin-dashboard__stats-row">
      <div class="admin-dashboard__stat">
        <span class="admin-dashboard__stat-value">@Model.MemberStats.Total.ToString("N0")</span>
        <span class="admin-dashboard__stat-label">Total members</span>
      </div>
      <div class="admin-dashboard__stat">
        <span class="admin-dashboard__stat-value">@Model.MemberStats.NewToday</span>
        <span class="admin-dashboard__stat-label">Joined today</span>
      </div>
      <div class="admin-dashboard__stat">
        <span class="admin-dashboard__stat-value">@Model.MemberStats.NewLast7Days</span>
        <span class="admin-dashboard__stat-label">Last 7 days</span>
      </div>
      <div class="admin-dashboard__stat">
        <span class="admin-dashboard__stat-value">@Model.MemberStats.NewLast30Days</span>
        <span class="admin-dashboard__stat-label">Last 30 days</span>
      </div>
    </div>

    <div class="admin-dashboard__sparkline-wrap">
      <span class="admin-dashboard__sparkline-label">New registrations — last 30 days</span>
      <svg class="admin-dashboard__sparkline"
           viewBox="0 0 @svgW @svgH"
           width="@svgW"
           height="@svgH"
           aria-hidden="true"
           xmlns="http://www.w3.org/2000/svg">
        <polyline fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linejoin="round"
                  stroke-linecap="round"
                  points="@polyline" />
      </svg>
    </div>
  </section>

  <section class="admin-dashboard__section">
    <h2 class="admin-dashboard__section-title">Traffic</h2>

    <div class="admin-dashboard__stats-row">
      <div class="admin-dashboard__stat">
        <span class="admin-dashboard__stat-value">@(Model.Traffic.IsAvailable ? Model.Traffic.SessionsLast7Days.ToString("N0") : "Unavailable")</span>
        <span class="admin-dashboard__stat-label">Sessions, last 7 days</span>
      </div>
      <div class="admin-dashboard__stat">
        <span class="admin-dashboard__stat-value">@(Model.Traffic.IsAvailable ? Model.Traffic.PageViewsLast7Days.ToString("N0") : "Unavailable")</span>
        <span class="admin-dashboard__stat-label">Page views, last 7 days</span>
      </div>
      <div class="admin-dashboard__stat">
        <span class="admin-dashboard__stat-value">@(Model.Traffic.IsAvailable ? Model.Traffic.ActiveUsersLast7Days.ToString("N0") : "Unavailable")</span>
        <span class="admin-dashboard__stat-label">Active users, last 7 days</span>
      </div>
    </div>

    @if (Model.Traffic.IsAvailable)
    {
      <div class="admin-dashboard__traffic-grid">
        <div class="admin-dashboard__traffic-chart">
          <span class="admin-dashboard__sparkline-label">Daily sessions, last 30 days</span>
          <div class="admin-dashboard__traffic-bars" aria-label="Daily sessions for the last 30 days">
            @foreach (var sessions in trafficDays)
            {
              <span class="admin-dashboard__traffic-bar"
                    style="height: @TrafficBarHeight(sessions)"
                    title="@sessions.ToString("N0") sessions"></span>
            }
          </div>
        </div>

        <div class="admin-dashboard__top-pages">
          <h3 class="admin-dashboard__contributors-title">Top pages this week</h3>
          @if (Model.Traffic.TopPagesThisWeek.Count > 0)
          {
            <ol class="admin-dashboard__top-pages-list">
              @foreach (var page in Model.Traffic.TopPagesThisWeek)
              {
                <li class="admin-dashboard__top-pages-item">
                  <span class="admin-dashboard__top-pages-path">@(page.Path)</span>
                  <span class="admin-dashboard__top-pages-count">@(page.Views.ToString("N0"))</span>
                </li>
              }
            </ol>
          }
          else
          {
            <p class="admin-dashboard__empty">No page views recorded for this week.</p>
          }
        </div>
      </div>
    }
    else
    {
      <p class="admin-dashboard__empty">@Model.Traffic.UnavailableReason</p>
    }
  </section>

  @if (Model.RecentLogins.Count > 0)
  {
    <section class="admin-dashboard__section">
      <h2 class="admin-dashboard__section-title">Recent logins</h2>
      <ul class="admin-dashboard__login-list">
        @foreach (var login in Model.RecentLogins)
        {
          <li class="admin-dashboard__login-item">
            <partial name="_MemberAvatar" model='@(new MemberAvatarViewModel { DisplayName = login.DisplayName, MemberId = login.MemberId, HasAvatar = login.HasAvatar, UseThumbnail = true })' />
            <span class="admin-dashboard__login-name">@login.DisplayName</span>
            <time class="admin-dashboard__login-time"
                  datetime="@login.LastLoginAt.ToString("O")">
              @FormatRelative(login.LastLoginAt)
            </time>
          </li>
        }
      </ul>
    </section>
  }
  else
  {
    <section class="admin-dashboard__section">
      <h2 class="admin-dashboard__section-title">Recent logins</h2>
      <p class="admin-dashboard__empty">No logins recorded yet — login timestamps are tracked from this release onwards.</p>
    </section>
  }

  <section class="admin-dashboard__section">
    <h2 class="admin-dashboard__section-title">Submission queue</h2>
    <div class="admin-dashboard__queue-tiles">

      <a class="admin-dashboard__queue-tile" href="/admin/photo-submissions">
        <span class="admin-dashboard__queue-tile-label">Photos</span>
        <span class="admin-dashboard__queue-tile-count">@Model.SubmissionQueue.Photos.Pending</span>
        <span class="admin-dashboard__queue-tile-sub">pending review</span>
        <span class="admin-dashboard__queue-tile-meta">Today: @Model.SubmissionQueue.Photos.ReceivedToday &nbsp;&middot;&nbsp; This week: @Model.SubmissionQueue.Photos.ReceivedThisWeek</span>
      </a>

      <a class="admin-dashboard__queue-tile" href="/admin/news-suggestions">
        <span class="admin-dashboard__queue-tile-label">News suggestions</span>
        <span class="admin-dashboard__queue-tile-count">@Model.SubmissionQueue.NewsSuggestions.Pending</span>
        <span class="admin-dashboard__queue-tile-sub">pending review</span>
        <span class="admin-dashboard__queue-tile-meta">Today: @Model.SubmissionQueue.NewsSuggestions.ReceivedToday &nbsp;&middot;&nbsp; This week: @Model.SubmissionQueue.NewsSuggestions.ReceivedThisWeek</span>
      </a>

      <a class="admin-dashboard__queue-tile" href="/admin/articles">
        <span class="admin-dashboard__queue-tile-label">Articles</span>
        <span class="admin-dashboard__queue-tile-count">@Model.SubmissionQueue.Articles.Pending</span>
        <span class="admin-dashboard__queue-tile-sub">pending review</span>
        <span class="admin-dashboard__queue-tile-meta">Today: @Model.SubmissionQueue.Articles.ReceivedToday &nbsp;&middot;&nbsp; This week: @Model.SubmissionQueue.Articles.ReceivedThisWeek</span>
      </a>

    </div>

    @{
      var total30 = Model.SubmissionQueue.TotalLast30Days;
      var approved30 = Model.SubmissionQueue.TotalApprovedLast30Days;
      var rejected30 = Model.SubmissionQueue.TotalRejectedLast30Days;
      var pending30 = Model.SubmissionQueue.TotalStillPendingLast30Days;
    }
    <div class="admin-dashboard__approval-rate">
      <span class="admin-dashboard__approval-rate-label">Last 30 days:</span>
      @if (total30 > 0)
      {
        <span class="admin-dashboard__approval-rate-stat admin-dashboard__approval-rate-stat--approved">
          Approved @((approved30 * 100 / total30))%
        </span>
        <span class="admin-dashboard__approval-rate-sep">&middot;</span>
        <span class="admin-dashboard__approval-rate-stat admin-dashboard__approval-rate-stat--rejected">
          Rejected @((rejected30 * 100 / total30))%
        </span>
        <span class="admin-dashboard__approval-rate-sep">&middot;</span>
        <span class="admin-dashboard__approval-rate-stat admin-dashboard__approval-rate-stat--pending">
          Pending @((pending30 * 100 / total30))%
        </span>
        <span class="admin-dashboard__approval-rate-total">(@total30 total)</span>
      }
      else
      {
        <span class="admin-dashboard__approval-rate-empty">No submissions in the last 30 days.</span>
      }
    </div>

    @if (Model.SubmissionQueue.TopContributors.Count > 0)
    {
      <div class="admin-dashboard__contributors">
        <h3 class="admin-dashboard__contributors-title">Top contributors this month</h3>
        <ol class="admin-dashboard__contributors-list">
          @foreach (var contributor in Model.SubmissionQueue.TopContributors)
          {
            <li class="admin-dashboard__contributors-item">
              <span class="admin-dashboard__contributors-name">@contributor.DisplayName</span>
              <span class="admin-dashboard__contributors-count">@contributor.Count</span>
            </li>
          }
        </ol>
      </div>
    }
  </section>
</div>

@functions {
    private static string FormatRelative(DateTime utc)
    {
        var diff = DateTime.UtcNow - utc;
        if (diff.TotalMinutes < 2) return "just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes} mins ago";
        if (diff.TotalHours < 2) return "1 hour ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours} hours ago";
        if (diff.TotalDays < 2) return "yesterday";
        return $"{(int)diff.TotalDays} days ago";
    }
}
