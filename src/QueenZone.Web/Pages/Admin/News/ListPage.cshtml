@page "/admin/news/page/{pageNumber:int}"
@model ListPageModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
  var antiforgeryToken = Antiforgery.GetAndStoreTokens(HttpContext).RequestToken;
}

<div class="admin-shell">
  <partial name="_AdminNewsList" model="AdminNewsListViewModel.FromPageModel(Model, antiforgeryToken ?? string.Empty)" />
</div>
