@page "/admin/news/{id:int}/edit"
@model EditModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
  ViewData["AntiforgeryToken"] = Antiforgery.GetAndStoreTokens(HttpContext).RequestToken;
}

<div class="admin-shell">
  @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
  {
    <p class="admin-status admin-status--@Model.StatusMessageKind">@Model.StatusMessage</p>
  }
  <partial name="_ArticleForm" model="Model.Form" />
</div>
