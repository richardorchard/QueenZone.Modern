@page "/"
@model IndexModel
@using System.Text.Json
@inject IFileVersionProvider FileVersionProvider
@{
    var eraSlides = HomeEraMontage.GetSlides(FileVersionProvider, HttpContext.Request.PathBase);
    var eraConfigJson = JsonSerializer.Serialize(eraSlides, new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase });
}

<section class="qz-hero-archive" id="qz-hero-archive" aria-label="Homepage hero">
  <div class="qz-hero-archive__glow" id="qz-era-glow" aria-hidden="true"></div>
  <partial name="_PictureImage" model="@("/design-system/assets/crest-white.png", "", false, "qz-hero-archive__crest")" />

  <div class="qz-container qz-hero-archive__inner">

    <!-- Editorial column -->
    <div class="qz-hero-archive__editorial">
      <div class="qz-eyebrow qz-hero-archive__badge">The Archive</div>
      <h1 class="qz-hero-archive__title">Twenty-five years of the Queen internet zone</h1>
      <p class="qz-hero-archive__standfirst">From hand-coded HTML in 1999 to the community&#8217;s final form &#8212; every era of Queenzone.com, restored and morphed into one living home.</p>
      <div class="qz-hero-archive__actions">
        <a class="qz-button qz-button--cta" href="/timeline">Explore the timeline</a>
        <span class="qz-hero-archive__meta">Est. 1999 &middot; queenzone.com</span>
      </div>
    </div>

    <!-- Morphing site-window stage -->
    <div class="qz-hero-archive__stage">
      <!-- Archive-stack ghost frames -->
      <div class="qz-hero-archive__ghost qz-hero-archive__ghost--far" aria-hidden="true"></div>
      <div class="qz-hero-archive__ghost qz-hero-archive__ghost--near" aria-hidden="true"></div>

      <!-- macOS-style browser window -->
      <div class="qz-hero-archive__window" aria-hidden="true">
        <div class="qz-hero-archive__titlebar">
          <span class="qz-hero-archive__dot"></span>
          <span class="qz-hero-archive__dot"></span>
          <span class="qz-hero-archive__dot"></span>
          <span class="qz-hero-archive__era-label" id="qz-era-label">The Queen Internet Zone</span>
          <span class="qz-hero-archive__era-year" id="qz-era-year">1999</span>
        </div>
        <div class="qz-hero-archive__viewport">
          <img class="qz-hero-archive__screenshot" id="qz-era-img"
               src="@eraSlides[0].Img"
               alt="Queenzone.com in @eraSlides[0].Year"
               loading="eager" fetchpriority="high" width="800" height="600">
          <div class="qz-hero-archive__overlay"></div>
        </div>
      </div>

      <!-- Era ticker -->
      <div class="qz-hero-archive__ticker" role="group" aria-label="Browse Queenzone eras">
        <button class="qz-era-btn qz-era-btn--active" data-era="0" aria-pressed="true">1999<span class="qz-era-btn__pip"></span></button>
        <button class="qz-era-btn" data-era="1" aria-pressed="false">2000<span class="qz-era-btn__pip"></span></button>
        <button class="qz-era-btn" data-era="2" aria-pressed="false">2002<span class="qz-era-btn__pip"></span></button>
        <button class="qz-era-btn" data-era="3" aria-pressed="false">2004<span class="qz-era-btn__pip"></span></button>
        <button class="qz-era-btn" data-era="4" aria-pressed="false">2020<span class="qz-era-btn__pip"></span></button>
      </div>
    </div>

  </div>
</section>
<script type="application/json" id="qz-era-config">@Html.Raw(eraConfigJson)</script>

<section class="qz-section qz-section--warm">
  <div class="qz-container">
    <partial name="_SectionHeader" model="@(("Explore the Archive", "Five ways into Queenzone", false, (string?)null, (string?)null))" />
    <div class="qz-grid qz-grid--five">
      <a class="qz-card" href="/news"><div class="qz-card__kicker">News archive</div><h3>4,000+ articles</h3><p>Chronological archive entries and newly approved editorial news.</p></a>
      <a class="qz-card" href="/articles"><div class="qz-card__kicker">Articles</div><h3>Features and essays</h3><p>Restored editorial features and long-form archive packages from Queenzone.com.</p></a>
      <a class="qz-card" href="/biography"><div class="qz-card__kicker">Biography</div><h3>The Queen story</h3><p>Year-marked chapters from the preserved Queenzone biography archive.</p></a>
      <a class="qz-card" href="/photography"><div class="qz-card__kicker">Photography</div><h3>Restored images</h3><p>A cinematic gallery pattern for the future photographic archive.</p></a>
      <a class="qz-card" href="/forum"><div class="qz-card__kicker">Forum history</div><h3>100,000+ posts</h3><p>Read-only community history prepared for modern browsing.</p></a>
    </div>
  </div>
</section>

<section class="qz-section qz-band-dark">
  <partial name="_PictureImage" model="@("/design-system/assets/crest-white.png", "", false, "qz-band-dark__crest")" />
  <div class="qz-container">
    <partial name="_SectionHeader" model="@(("Featured", "Articles from the archive", true, "/articles", "View all"))" />
    <div class="qz-tag-row">
      <span class="qz-tag qz-tag--active">All</span><span class="qz-tag qz-tag--dark">Live Aid</span><span class="qz-tag qz-tag--dark">Freddie Mercury</span><span class="qz-tag qz-tag--dark">Recordings</span>
    </div>
    <div class="qz-grid qz-grid--three">
      <partial name="_ArticleCard" model="@("/design-system/assets/img-studio.jpg", "Recording", "Inside the Making of Bohemian Rhapsody", "Six weeks, three studios and a chorus recorded more than 180 times.", "Restored archive", "/articles/101/inside-the-making-of-bohemian-rhapsody", true)" />
      <partial name="_ArticleCard" model="@("/design-system/assets/img-portrait.jpg", "In Memoriam", "Freddie: The Voice That Defined an Era", "A presence no stadium could contain, preserved through archive voices.", "9 min read", "/articles/102/freddie-the-voice-that-defined-an-era", true)" />
      <partial name="_ArticleCard" model="@("/design-system/assets/img-crowd.jpg", "Live History", "The Magic Tour, Night by Night", "The 1986 run that became the final tour with all four members.", "15 min read", "/articles/103/the-magic-tour-night-by-night", true)" />
    </div>
  </div>
</section>

<section class="qz-section">
  <div class="qz-container">
    <partial name="_SectionHeader" model="@(("Latest", "Latest news", false, "/news", "View all"))" />
    @if (Model.Latest.Count == 0)
    {
      <p>No published news is available yet.</p>
    }
    else
    {
      <ol class="qz-news-list">
        @foreach (var item in Model.Latest)
        {
          <li class="qz-news-row">
            <div class="qz-meta"><time datetime="@item.PublishedAt.ToString("yyyy-MM-dd")">@item.PublishedAt.ToString("dd MMMM yyyy")</time></div>
            <div>
              <h3><a href="@NewsRoutes.GetNewsDetailPath(item)">@item.Title</a></h3>
              <p>@item.Excerpt</p>
            </div>
          </li>
        }
      </ol>
    }
  </div>
</section>

<section class="qz-section qz-section--warm">
  <div class="qz-container">
    <partial name="_SectionHeader" model="@(("Featured Photography", "A visual archive in progress", false, "/photography", "Browse gallery"))" />
    <div class="qz-gallery-grid">
      <figure class="qz-gallery-tile qz-gallery-tile--tall"><partial name="_PictureImage" model="@("/design-system/assets/img-stage.jpg", "", true, (string?)null)" /><figcaption><span>Wembley Stadium</span><span>1986</span></figcaption></figure>
      <figure class="qz-gallery-tile"><partial name="_PictureImage" model="@("/design-system/assets/img-portrait.jpg", "", true, (string?)null)" /><figcaption><span>Studio portrait</span><span>1974</span></figcaption></figure>
      <figure class="qz-gallery-tile qz-gallery-tile--wide"><partial name="_PictureImage" model="@("/design-system/assets/img-crowd.jpg", "", true, (string?)null)" /><figcaption><span>Hyde Park</span><span>1976</span></figcaption></figure>
      <figure class="qz-gallery-tile"><partial name="_PictureImage" model="@("/design-system/assets/img-studio.jpg", "", true, (string?)null)" /><figcaption><span>Mountain Studios</span><span>1978</span></figcaption></figure>
    </div>
  </div>
</section>

<section class="qz-section qz-band-dark">
  <div class="qz-container">
    <partial name="_SectionHeader" model="@(("On This Day", "This Day in Queen History", true, "/timeline", "View timeline"))" />
    @if (Model.OnThisDay.Count == 0)
    {
      <p>No exact Queen history records are available for today yet.</p>
    }
    else
    {
      @if (Model.IsOnThisDayFallback)
      {
        <p class="qz-on-this-day-note">No exact match for today yet. Showing nearby dates from the archive.</p>
      }
      <div class="qz-grid qz-grid--three qz-on-dark qz-on-this-day-grid">
        @foreach (var item in Model.OnThisDay)
        {
          <article class="qz-on-this-day-item">
            <div class="qz-card__kicker">
              <time datetime="@item.EventDate.ToString("yyyy-MM-dd")">@item.FormattedDate</time>
            </div>
            <h3>@item.Title</h3>
            <p>@item.Summary</p>
            <div class="qz-on-this-day-item__category">@item.Category</div>
          </article>
        }
      </div>
    }
  </div>
</section>
