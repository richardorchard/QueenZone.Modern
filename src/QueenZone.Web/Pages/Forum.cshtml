@page "/forum"
@model ForumModel
@{
  ViewData["Title"] = "Forum";
  ViewData["Description"] = "Read-only Queenzone forum archive boards and community history.";
}

<section class="qz-page-hero">
  <partial name="_PictureImage" model="@("/design-system/assets/crest-white.png", "", false, "qz-page-hero__crest")" />
  <div class="qz-container qz-breadcrumbs-on-dark">
    <partial name="_Breadcrumbs" model="Model.Breadcrumbs" />
    <div class="qz-eyebrow" style="color: var(--qz-gold);">Community Archive</div>
    <h1>Forum</h1>
    <p class="lede" style="max-width: var(--container-text);">A read-only modern index for the original community discussions, boards and recent thread patterns.</p>
    <div class="qz-forum-stats">
      <span><strong>@Model.Stats.ForumCount.ToString("N0")</strong> boards</span>
      <span><strong>@ForumRoutes.FormatCount(Model.Stats.ThreadCount)</strong> threads</span>
      <span><strong>@ForumRoutes.FormatCount(Model.Stats.PostCount)</strong> posts</span>
    </div>
  </div>
</section>

<section class="qz-section qz-section--warm">
  <div class="qz-container">
    <partial name="_SectionHeader" model="@(("Boards", "Browse the community archive", false, "/search", "Search forum"))" />
    @if (Model.Categories.Count == 0)
    {
      <p>No forum boards are available yet.</p>
    }
    else
    {
      <div class="qz-grid qz-grid--three">
        @foreach (var category in Model.Categories)
        {
          <a class="qz-card" href="@category.DetailPath">
            <div class="qz-card__kicker">@category.Name</div>
            <h3>@(string.IsNullOrWhiteSpace(category.Description) ? category.Name : category.Description)</h3>
            @if (!string.IsNullOrWhiteSpace(category.LatestThreadTitle))
            {
              <p>
                Latest:
                @category.LatestThreadTitle
                @if (category.LastActivityAt is not null)
                {
                  <span class="qz-meta"> · <time datetime="@category.LastActivityAt.Value.ToString("yyyy-MM-dd")">@category.LastActivityAt.Value.ToString("dd MMMM yyyy")</time></span>
                }
              </p>
            }
            else if (category.LastActivityAt is not null)
            {
              <p class="qz-meta"><time datetime="@category.LastActivityAt.Value.ToString("yyyy-MM-dd")">Last activity @category.LastActivityAt.Value.ToString("dd MMMM yyyy")</time></p>
            }
            else
            {
              <p class="qz-meta">@ForumRoutes.FormatCount(category.PostCount) posts</p>
            }
          </a>
        }
      </div>
    }
  </div>
</section>

<section class="qz-section">
  <div class="qz-container">
    <partial name="_SectionHeader" model="@(("Recent Threads", "Activity pattern", false, (string?)null, (string?)null))" />
    <table class="qz-table">
      <thead><tr><th>Thread</th><th>Board</th><th>Replies</th><th>Latest</th></tr></thead>
      <tbody>
        <tr><td>The definitive ranking of every studio album</td><td>The Music</td><td>1,284</td><td>2h ago</td></tr>
        <tr><td>Unheard Montreux session tapes</td><td>Rarities</td><td>642</td><td>5h ago</td></tr>
        <tr><td>Restoring the 1977 News of the World tour photos</td><td>Archive Project</td><td>318</td><td>1d ago</td></tr>
      </tbody>
    </table>
  </div>
</section>